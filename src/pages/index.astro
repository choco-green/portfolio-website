---
import "../styles/global.css";
import Navigation from "../components/portfolio/organisms/Navigation";
import HeroSection from "../components/portfolio/organisms/HeroSection";
import ExperienceTimeline from "../components/portfolio/organisms/ExperienceTimeline";
import ProjectsSection from "../components/portfolio/organisms/ProjectsSection";
import SkillsSection from "../components/portfolio/organisms/SkillsSection";
import ContactSection from "../components/portfolio/organisms/ContactSection";
import { preparePortfolioImages } from "../components/portfolio/prepareImages";
import { contactSocialActions, projects, skillGroups } from "../components/portfolio/content";

const siteName = "Justin Fung Portfolio";
const title = "Justin Fung | Full-Stack Engineer";
const description =
  "Justin Fung is a full-stack engineer building React, TypeScript, Node.js, and Rust products across healthcare, education, and developer tools.";
const canonicalUrl = "https://justinfung.com/";
const portfolioImages = await preparePortfolioImages();
const site = Astro.site ?? new URL(canonicalUrl);
const heroPortraitUrl = new URL(portfolioImages.heroPortrait.src, site).toString();
const socialProfiles = ["https://github.com/choco-green", "https://www.linkedin.com/in/justin-fung-nsb"];
const portfolioResources = [
  { label: "API Docs", href: "/docs/api/" },
  { label: "OpenAPI", href: "/openapi.json" },
  { label: "Health", href: "/health.json" },
  { label: "Authentication", href: "/auth.md" },
  { label: "Agent Skills", href: "/.well-known/agent-skills/index.json" },
  { label: "Sitemap", href: "/sitemap.xml" }
];

const person = {
  "@type": "Person",
  "@id": `${canonicalUrl}#person`,
  name: "Justin Fung",
  url: canonicalUrl,
  jobTitle: "Full-stack engineer",
  image: heroPortraitUrl,
  email: "mailto:justin--fung@outlook.com",
  sameAs: socialProfiles,
  knowsAbout: [
    "TypeScript",
    "React",
    "Next.js",
    "Node.js",
    "NestJS",
    "Rust",
    "Postgres",
    "Docker",
    "Testing"
  ],
  alumniOf: {
    "@type": "CollegeOrUniversity",
    name: "University of Leicester"
  },
  knowsLanguage: ["English", "Chinese", "German"]
};

const profilePage = {
  "@type": "ProfilePage",
  "@id": `${canonicalUrl}#profile`,
  url: canonicalUrl,
  name: title,
  description,
  inLanguage: "en",
  about: {
    "@id": person["@id"]
  },
  mainEntity: person,
  primaryImageOfPage: {
    "@type": "ImageObject",
    url: heroPortraitUrl
  },
  isPartOf: {
    "@id": `${canonicalUrl}#website`
  }
};

const website = {
  "@type": "WebSite",
  "@id": `${canonicalUrl}#website`,
  url: canonicalUrl,
  name: siteName,
  description,
  inLanguage: "en",
  publisher: {
    "@id": person["@id"]
  }
};

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [person, profilePage, website]
};

const webMcpData = JSON.stringify({
  profile: {
    name: person.name,
    role: person.jobTitle,
    homepage: canonicalUrl,
    resume: "https://justinfung.com/resume/download",
    contacts: contactSocialActions.map(({ label, detail, href }) => ({ label, detail, href })),
    skills: skillGroups.map(({ title, items }) => ({ title, items }))
  },
  projects: projects.map(({ title, summary, tags, url }) => ({ title, summary, tags, url }))
}).replaceAll("<", "\\u003c");

const webMcpScript = `(() => {
  const data = ${webMcpData};
  const modelContext = navigator.modelContext;

  if (!modelContext || typeof modelContext.provideContext !== "function") {
    return;
  }

  const emptyInputSchema = {
    type: "object",
    additionalProperties: false,
    properties: {}
  };

  modelContext.provideContext({
    name: "Justin Fung Portfolio",
    version: "1.0.0",
    tools: [
      {
        name: "get_portfolio_profile",
        description: "Return Justin Fung's profile, contact links, resume URL, skills, and public project list.",
        inputSchema: emptyInputSchema,
        execute: async () => ({
          ...data.profile,
          projects: data.projects
        })
      },
      {
        name: "list_portfolio_projects",
        description: "Return Justin Fung's public project summaries and source URLs.",
        inputSchema: emptyInputSchema,
        execute: async () => data.projects
      },
      {
        name: "get_contact_links",
        description: "Return public email, GitHub, LinkedIn, and resume links.",
        inputSchema: emptyInputSchema,
        execute: async () => ({
          contacts: data.profile.contacts,
          resume: data.profile.resume
        })
      }
    ]
  });
})();`;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="application-name" content={siteName} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Justin Fung" />
    <meta name="robots" content="index, follow" />
    <meta name="googlebot" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical" href={canonicalUrl} />
    {socialProfiles.map((profile) => <link rel="me" href={profile} />)}
    <meta property="og:type" content="profile" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:title" content={title} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={heroPortraitUrl} />
    <meta property="og:image:alt" content="Portrait of Justin Fung, full-stack engineer" />
    <meta property="profile:first_name" content="Justin" />
    <meta property="profile:last_name" content="Fung" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={heroPortraitUrl} />
    <meta name="twitter:image:alt" content="Portrait of Justin Fung, full-stack engineer" />
    <script is:inline>
      (() => {
        const key = "portfolio-theme";
        const root = document.documentElement;
        const stored = window.localStorage.getItem(key);
        const system = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
        root.dataset.theme = stored === "light" || stored === "dark" ? stored : system;
      })();
    </script>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <script is:inline set:html={webMcpScript} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <Navigation client:idle />
    <main id="main-content" tabindex="-1">
      <HeroSection portrait={portfolioImages.heroPortrait} />
      <ExperienceTimeline entries={portfolioImages.experienceEntries} client:visible={{ rootMargin: "120px" }} />
      <ProjectsSection projects={portfolioImages.projects} />
      <SkillsSection />
      <ContactSection />
    </main>
    <footer aria-labelledby="portfolio-resources-heading" class="border-t border-line bg-canvas px-4 py-8 sm:px-6 lg:px-8">
      <div class="mx-auto flex max-w-7xl flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <h2 id="portfolio-resources-heading" class="font-mono text-sm font-bold uppercase text-muted">Portfolio resources</h2>
        <nav aria-label="Portfolio resources">
          <ul class="flex flex-wrap gap-2">
            {
              portfolioResources.map((resource) => (
                <li>
                  <a
                    class="inline-flex min-h-10 items-center rounded-md border border-line bg-raised px-3 py-2 text-sm font-bold text-muted transition hover:border-accent hover:text-accent-strong focus-visible:text-accent-strong"
                    href={resource.href}
                  >
                    {resource.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>
    </footer>
  </body>
</html>
