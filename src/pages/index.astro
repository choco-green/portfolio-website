---
import "../styles/global.css";
import Navigation from "../components/portfolio/organisms/Navigation";
import HeroSection from "../components/portfolio/organisms/HeroSection";
import ExperienceTimeline from "../components/portfolio/organisms/ExperienceTimeline";
import ProjectsSection from "../components/portfolio/organisms/ProjectsSection";
import SkillsSection from "../components/portfolio/organisms/SkillsSection";
import ContactSection from "../components/portfolio/organisms/ContactSection";
import { preparePortfolioImages } from "../components/portfolio/prepareImages";

const siteName = "Justin Fung Portfolio";
const title = "Justin Fung | Full-Stack Engineer";
const description =
  "Justin Fung is a full-stack engineer in Germany building React, Next.js, TypeScript, Node.js, and Rust products across healthcare, education, and developer tools.";
const canonicalUrl = "https://justinfung.com/";
const portfolioImages = await preparePortfolioImages();
const site = Astro.site ?? new URL(canonicalUrl);
const heroPortraitUrl = new URL(portfolioImages.heroPortrait.src, site).toString();
const socialProfiles = ["https://github.com/choco-green", "https://www.linkedin.com/in/justin-fung-nsb"];

const person = {
  "@type": "Person",
  "@id": `${canonicalUrl}#person`,
  name: "Justin Fung",
  url: canonicalUrl,
  jobTitle: "Full-stack engineer",
  image: heroPortraitUrl,
  email: "mailto:justin--fung@outlook.com",
  sameAs: socialProfiles,
  knowsAbout: [
    "TypeScript",
    "React",
    "Next.js",
    "Node.js",
    "NestJS",
    "Rust",
    "Postgres",
    "Docker",
    "Testing"
  ],
  address: {
    "@type": "PostalAddress",
    addressCountry: "DE"
  },
  alumniOf: {
    "@type": "CollegeOrUniversity",
    name: "University of Leicester"
  },
  knowsLanguage: ["English", "Chinese", "German"]
};

const profilePage = {
  "@type": "ProfilePage",
  "@id": `${canonicalUrl}#profile`,
  url: canonicalUrl,
  name: title,
  description,
  inLanguage: "en",
  about: {
    "@id": person["@id"]
  },
  mainEntity: person,
  primaryImageOfPage: {
    "@type": "ImageObject",
    url: heroPortraitUrl
  },
  isPartOf: {
    "@id": `${canonicalUrl}#website`
  }
};

const website = {
  "@type": "WebSite",
  "@id": `${canonicalUrl}#website`,
  url: canonicalUrl,
  name: siteName,
  description,
  inLanguage: "en",
  publisher: {
    "@id": person["@id"]
  }
};

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [person, profilePage, website]
};
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="application-name" content={siteName} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Justin Fung" />
    <meta name="robots" content="index, follow" />
    <meta name="googlebot" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical" href={canonicalUrl} />
    {socialProfiles.map((profile) => <link rel="me" href={profile} />)}
    <meta property="og:type" content="profile" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:title" content={title} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={heroPortraitUrl} />
    <meta property="og:image:alt" content="Portrait of Justin Fung, full-stack engineer" />
    <meta property="profile:first_name" content="Justin" />
    <meta property="profile:last_name" content="Fung" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={heroPortraitUrl} />
    <meta name="twitter:image:alt" content="Portrait of Justin Fung, full-stack engineer" />
    <script is:inline>
      (() => {
        const key = "portfolio-theme";
        const root = document.documentElement;
        const stored = window.localStorage.getItem(key);
        const system = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
        root.dataset.theme = stored === "light" || stored === "dark" ? stored : system;
      })();
    </script>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <Navigation client:idle />
    <main id="main-content" tabindex="-1">
      <HeroSection portrait={portfolioImages.heroPortrait} />
      <ExperienceTimeline entries={portfolioImages.experienceEntries} client:visible={{ rootMargin: "120px" }} />
      <ProjectsSection projects={portfolioImages.projects} />
      <SkillsSection />
      <ContactSection />
    </main>
  </body>
</html>
